{
  "installCommand": "git clone https://github.com/flutter/flutter.git -b stable --depth 1 .flutter && ./.flutter/bin/flutter config --enable-web",
  "buildCommand": "./.flutter/bin/flutter build web --release --dart-define=SUPABASE_URL=$SUPABASE_URL --dart-define=SUPABASE_ANON_KEY=$SUPABASE_ANON_KEY",
  "outputDirectory": "build/web",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
